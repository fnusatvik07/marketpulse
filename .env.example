# LLM
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Oxylabs Web Scraper API (free trial at dashboard.oxylabs.io)
# Leave empty to run in MOCK mode with saved fixture data.
OXYLABS_USERNAME=
OXYLABS_PASSWORD=

# Force mock mode even with credentials present
# OXYLABS_MOCK=true

# Marketplace (in, com, co.uk ...)
# AMAZON_DOMAIN=in

# Memory (defaults match docker-compose.yml)
# POSTGRES_URI=postgresql://postgres:postgres@localhost:5442/marketpulse?sslmode=disable

# Summarization knobs
# MAX_MESSAGES=12
# KEEP_LAST=6
